{
  "compilerOptions": {
    "target": "ES2022",
    "module": "CommonJS",
    "moduleResolution": "Node",
    "lib": ["ES2022"],
    "types": ["node"],
    "outDir": "../dist",
    "rootDir": "..",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "declaration": false,
    "sourceMap": true,
    "paths": {
      "@/*": ["../*"]
    }
  },
  "include": ["**/*.ts", "../lib/**/*.ts"],
  "exclude": [
    "**/*.test.ts",
    "../lib/**/*.test.ts",
    "../lib/publish/**"
  ]
}
